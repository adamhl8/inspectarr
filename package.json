{
  "name": "inspectarr",
  "version": "1.3.2",
  "private": true,
  "description": "A CLI tool for querying and inspecting the media in your Radarr and Sonarr instances",
  "keywords": [
    "arr",
    "data",
    "filter",
    "inspect",
    "query",
    "radarr",
    "servarr",
    "sonarr"
  ],
  "homepage": "https://github.com/adamhl8/inspectarr",
  "bugs": {
    "url": "https://github.com/adamhl8/inspectarr/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamhl8/inspectarr"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#package.json": "./package.json"
  },
  "scripts": {
    "lint": "markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && oxfmt && oxlint --fix --fix-suggestions --fix-dangerously && adamhl8-knip",
    "bump-deps": "nub update -L && rm -f lock.yaml && nub i && oxfmt lock.yaml",
    "bundle": "nub run lint",
    "release": "gh workflow run release.yml",
    "release:run": "release-it --ci -i \"$(adamhl8-cliff --bumped-version)\"",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@optique/core": "^1.1.1",
    "@optique/run": "^1.1.1",
    "es-toolkit": "^1.49.0",
    "filterql": "^3.0.3",
    "ky": "^2.0.2",
    "tablemark": "4.1.0",
    "ts-explicit-errors": "^4.1.2",
    "ts-extras": "^1.2.0"
  },
  "devDependencies": {
    "@adamhl8/configs": "^0.24.13",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "knip": "^6.24.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "release-it": "^20.2.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3"
  }
}
